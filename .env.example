# Backend API Port
PORT=4000

# Redis Cache
REDIS_URL=redis://redis:6379

# PostgreSQL Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=kodingin
DATABASE_URL=postgres://postgres:your_secure_db_password@postgres:5432/kodingin

# Better Auth Configuration (Change URLs for your production domain, e.g., https://kodingin.com)
BETTER_AUTH_SECRET=super_secret_key_change_me_in_production
BETTER_AUTH_URL=https://kodingin.com
FRONTEND_URL=https://kodingin.com

# Frontend Configuration (Used during Vite build)
VITE_API_URL=https://kodingin.com
